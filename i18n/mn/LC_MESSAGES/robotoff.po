# Question that appears for logged-in users on the Web and Android
msgid "Does the product belong to this category?"
msgstr "Бүтээгдэхүүн энэ ангилалд хамаарах уу?"

# Question that appears for logged-in users on the Web and Android
msgid "Does the product have this label?"
msgstr "Бүтээгдэхүүнд энэ шошго байгаа юу?"

# Question that appears for logged-in users on the Web and Android
msgid "Does the product belong to this brand?"
msgstr "Бүтээгдэхүүн нь энэ брэндийнх үү?"

# Question that appears for logged-in users on the Web and Android
msgid "Does this weight match the weight displayed on the product?"
msgstr "Энэ жин нь бүтээгдэхүүн дээр заасан жинтэй тохирч байна уу?"

# Question that appears for logged-in users on the Web and Android
msgid "Is this image a nutrition image for this language?"
msgstr "Энэ зураг энэ хэлний хоол тэжээлийн зураг мөн үү?"

# Question that appears for logged-in users on the Web and Android
msgid "Does the product have this packaging element?"
msgstr "Бүтээгдэхүүнд энэ сав баглаа боодлын элемент байгаа юу?"

# Question that appears for logged-in users on the Web and Android
msgid "Is this image rotated with the following orientation?"
msgstr "Энэ зургийг дараах байдлаар эргүүлсэн үү?"

